0CF5: EB                    xchg
0CF6: C9                    ret

                    ; -----------------------------------------------------------------------
                    ; move_and_check_soul -- move one soul "()" and check helicopter collision
                    ; Input:  HL = pointer to soul entry (2 bytes: row, column)
                    ; Output: HL = pointer past this entry (+2)
                    ;
                    ; Soul data: 2 bytes per soul in souls_positions array
                    ;   byte 0: row  (Y coordinate)
                    ;   byte 1: column (X coordinate)
                    ;
                    ; Movement: partially seeks the helicopter with random element
                    ;   Vertical:  1/3 move up, 1/3 stay, 1/3 move toward helicopter
                    ;   Horizontal: 1/2 stay, 1/2 move toward helicopter
                    ; If new position is blocked (not space), reverts to old position.
                    ; If soul touches 'O' (helicopter cockpit), triggers crash.
                    ; Maps to Python's soul update loop with random walk + bounce.
                    ; -----------------------------------------------------------------------
0CF7:               move_and_check_soul:     ; offset=0CF7h
0CF7: C5                    push b
0CF8: 5E                    mov  e, m     ; e = current soul row
0CF9: 4B                    mov  c, e     ; c = new row (default: same)

                            ; -- vertical movement --
0CFA: 3E 02                 mvi  a, 2
0CFC: CD F7 05              call random              ; a = [0..2]
0CFF: 3D                    dcr  a                   ; a = -1 (up), 0 (stay), or 1
0D00: EA 0A 0D              jpe  soul_vert_apply     ; parity even for -1 and 0: random move
                            ; parity odd (a=1): seek helicopter vertically
0D03: 3A 9C 0F              lda  helicopter_xy     ; helicopter row
0D06: BB                    cmp  e                 ; compare with soul row
0D07: 9F                    sbb  a                 ; 0x00 if heli below, 0xFF if heli above
0D08: F6 01                 ori  1                 ; +1 (move down) or -1 (move up) toward heli

0D0A:               soul_vert_apply:                 ; offset=0D0Ah
0D0A: 83                    add  e                  ; new_row = soul_row + delta
0D0B: FE 19                 cpi  19h                ; >= 25? (off screen)
0D0D: D2 11 0D              jnc  soul_vert_skip     ; out of bounds -> keep old row
0D10: 4F                    mov  c, a               ; c = new row (accepted)

0D11:               soul_vert_skip:                 ; offset=0D11h
                            ; -- horizontal movement --
0D11: 23                    inx  h
0D12: 56                    mov  d, m                 ; d = current soul column
0D13: 42                    mov  b, d                 ; b = new column (default: same)
0D14: 3E 01                 mvi  a, 1
0D16: CD F7 05              call random               ; a = [0..1]
0D19: B7                    ora  a
0D1A: CA 24 0D              jz   soul_horiz_apply     ; 0 -> no horizontal movement
                            ; seek helicopter horizontally
0D1D: 3A 9D 0F              lda  helicopter_xy+1     ; helicopter column
0D20: BA                    cmp  d                   ; compare with soul column
0D21: 9F                    sbb  a                   ; 0x00 if heli right, 0xFF if heli left
0D22: F6 01                 ori  1                   ; +1 or -1 toward helicopter

0D24:               soul_horiz_apply:                 ; offset=0D24h
0D24: 82                    add  d                   ; new_col = soul_col + delta
0D25: FE 3F                 cpi  3Fh                 ; >= 63?
0D27: D2 2B 0D              jnc  soul_check_dest     ; out of bounds -> keep old col
0D2A: 47                    mov  b, a                ; b = new column (accepted)

0D2B:               soul_check_dest:                 ; offset=0D2Bh
                            ; -- check collision at new position --
                            ; c=new_row, b=new_col, e=old_row, d=old_col
0D2B: E5                    push h
0D2C: 79                    mov  a, c                    ; new row
0D2D: 68                    mov  l, b                    ; new column
0D2E: CD A0 05              call screen_area_address
0D31: 7E                    mov  a, m
0D32: FE 4F                 cpi  4Fh                     ; 'O' = helicopter cockpit?
0D34: CA 27 0C              jz   collision_condition     ; soul hits helicopter!
0D37: FE 20                 cpi  20h                     ; space = empty?
0D39: C2 48 0D              jnz  soul_blocked            ; blocked -> revert position
0D3C: 23                    inx  h                       ; check adjacent cell (soul is 2 chars "()")
0D3D: 7E                    mov  a, m
0D3E: FE 4F                 cpi  4Fh                     ; 'O'?
0D40: CA 27 0C              jz   collision_condition
0D43: FE 20                 cpi  20h                     ; space?
0D45: CA 4A 0D              jz   soul_draw               ; both cells clear -> accept move

0D48:               soul_blocked:          ; offset=0D48h
0D48: 42                    mov  b, d     ; revert: b = old column
0D49: 4B                    mov  c, e     ; revert: c = old row

0D4A:               soul_draw:     ; offset=0D4Ah
                            ; -- erase old and draw new "()" --
0D4A: E1                    pop  h

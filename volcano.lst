05EB: 42                    mov  b, d                     ; b = new x_pos_hi (column)
05EC: D1                    pop  d
05ED: 16 08                 mvi  d, 8                     ; d = row 8 (initial Y for drawing)
05EF: 7B                    mov  a, e
05F0: 69                    mov  l, c
05F1: CD A0 05              call screen_area_address

                    ; -----------------------------------------------------------------------
                    ; Explosion animation system
                    ;
                    ; explosion_plot_dot -- plot or erase one dot at offset (h,l) from center
                    ; Input: DE = center (row,col), H = X offset, L = Y offset, C = char (or 0)
                    ; If C=0, reads existing char from screen buffer (restore mode).
                    ; Bounds-checks: col < 64, row < 25. Skips if 'O' (helicopter) at target.
                    ; -----------------------------------------------------------------------
0C74:               explosion_plot_dot:                          ; offset=0C74h
0C74: 7C                    mov  a, h
0C75: 87                    add  a                              ; double X offset (accelerating expansion)
0C76: 67                    mov  h, a
0C77: 19                    dad  d                              ; hl = center + offset (h=col, l=row)
0C78: 7C                    mov  a, h
0C79: FE 40                 cpi  40h                            ; col >= 64?
0C7B: D0                    rnc                                 ; out of bounds
0C7C: 7D                    mov  a, l
0C7D: FE 19                 cpi  19h                            ; row >= 25?
0C7F: D0                    rnc                                 ; out of bounds
0C80: CD 9B 05              call set_cursor_in_screen_arena     ; set cursor + get buffer addr
0C83: 7E                    mov  a, m
0C84: FE 4F                 cpi  4Fh                            ; don't overwrite helicopter 'O'
0C86: C8                    rz
0C87: C5                    push b
0C88: 79                    mov  a, c
0C89: B7                    ora  a
0C8A: CC BD 0C              cz   explosion_read_char            ; c=0: restore mode, read original char
0C8D: CD 09 F8              call monitor_cout
0C90: C1                    pop  b
0C91: C9                    ret

                    ; explosion_radiate -- draw/erase 8 dots radiating from center

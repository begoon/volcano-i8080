                    ; -----------------------------------------------------------------------
                    ; random(max) -- pseudo-random number generator
                    ; Input:  A = max value (inclusive upper bound)
                    ; Output: A = random value in [0..max]
                    ;
                    ; Algorithm:
                    ;   1. Uses rng_seed (16-bit) as a pointer into low memory (0x0000-0x1FFF,
                    ;      the ROM monitor area on RK86) to read a byte for entropy.
                    ;   2. Mixes that byte with rng_accum and the max parameter.
                    ;   3. Advances the seed: rng_seed += (max << 8 | rng_accum) + 1
                    ;   4. Rejection sampling with a narrowing bitmask to produce an unbiased
                    ;      result in [0..max]: starts with mask=0xFF, halves it until
                    ;      (random_byte & mask) <= max.
                    ; -----------------------------------------------------------------------
05F7:               random:                     ; offset=05F7h
05F7: D5                    push d
05F8: E5                    push h
05F9: 57                    mov  d, a          ; d = max (parameter)
05FA: 2A 97 0F              lhld rng_seed
05FD: 3E 1F                 mvi  a, 1Fh
05FF: A4                    ana  h             ; h &= 0x1F -- limit pointer to 0x0000-0x1FFF
0600: 67                    mov  h, a
0601: 3A 99 0F              lda  rng_accum
0604: 86                    add  m             ; a += byte read from memory[rng_seed & 0x1FFF]
0605: 82                    add  d             ; a += max
0606: 32 99 0F              sta  rng_accum     ; save updated accumulator
0609: 5F                    mov  e, a          ; e = random byte
060A: 19                    dad  d             ; rng_seed += de (d=max, e=accum)
060B: 23                    inx  h             ; rng_seed += 1
060C: 22 97 0F              shld rng_seed
060F: 3E FF                 mvi  a, 0FFh       ; initial bitmask = 0xFF
0611: C3 16 06              jmp  rng_narrow_check

0614:               rng_narrow_mask:                        ; offset=0614h  mask >>= 1 (halve the mask)
0614: 7C                    mov  a, h
0615: 1F                    rar

0616:               rng_narrow_check:                       ; offset=0616h
0616: 67                    mov  h, a                ; h = current mask
0617: A3                    ana  e                   ; a = mask & random_byte
0618: BA                    cmp  d                   ; compare with max
0619: CA 1F 06              jz   rng_done            ; if == max, accept
061C: D2 14 06              jnc  rng_narrow_mask     ; if > max, narrow mask and retry
                            ; if < max, fall through and accept
061F:               rng_done:                               ; offset=061Fh
061F: E1                    pop  h
0620: D1                    pop  d
0621: C9                    ret


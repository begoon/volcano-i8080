0C93: CD AC 0C              call explosion_axis_dots     ; plot N, E, S (along axes)
0C96: 78                    mov  a, b
0C97: 2F                    cma
0C98: 3C                    inr  a                       ; a = -b (negate for opposite direction)
0C99: 67                    mov  h, a

                    ; -----------------------------------------------------------------------
                    ; set_cursor_in_screen_arena -- set terminal cursor AND return buffer addr
                    ; Input: H = column, L = row
                    ; Output: HL = screen_area buffer address, cursor positioned on screen
                    ; Combines set_cursor (for terminal) with screen_area_address_hl (for buffer).
                    ; -----------------------------------------------------------------------
059B:               set_cursor_in_screen_arena:     ; offset=059Bh
059B: CD 80 05              call set_cursor     ; set terminal cursor (Y=l, X=h)
                            ; fall through to screen_area_address_hl

                    ; screen_area_address_hl -- convert (row=L, col=H) to buffer address
                    ; Input: H = column, L = row
                    ; Output: HL = screen_area buffer address
059E:               screen_area_address_hl:     ; offset=059Eh
059E: 7D                    mov  a, l     ; a = row (swap: screen_area_address wants col in A)
059F: 6C                    mov  l, h     ; l = column
                            ; fall through to screen_area_address

                    ; -----------------------------------------------------------------------
                    ; screen_area_address -- convert (row, col) to screen buffer address
                    ; Input: A = column (0-63), L = row (0-24)
                    ; Output: HL = address in screen_area buffer
                    ;
                    ; RK86 screen layout: 64 columns x 25 rows, but memory is NOT linear.
                    ; Address = screen_area + (col >> 2) * 256 + (col & 3) * 64 + row
                    ;
                    ; The two RRC instructions rotate A (column) right by 2:
                    ;   A = [c1 c0 c7 c6 c5 c4 c3 c2]
                    ; Then H gets top 6 bits (col >> 2), and L gets (col & 3) * 64 + row.
                    ; This matches the RK86 video RAM interleaved bank layout.
                    ; -----------------------------------------------------------------------
05A0:               screen_area_address:     ; offset=05A0h
05A0: D5                    push d
05A1: 0F                    rrc           ; rotate column right (step 1 of 2)
05A2: 0F                    rrc           ; A = [c1 c0 c7 c6 c5 c4 c3 c2]
05A3: 67                    mov  h, a     ; save rotated value
05A4: E6 C0                 ani  0C0h     ; a = [c1 c0 0 0 0 0 0 0] = (col & 3) << 6
05A6: B5                    ora  l        ; a = (col & 3) * 64 + row
05A7: 6F                    mov  l, a     ; L = low byte of offset
05A8: 3E 3F                 mvi  a, 3Fh
05AA: A4                    ana  h        ; a = [0 0 c7 c6 c5 c4 c3 c2] = col >> 2
05AB: 67                    mov  h, a     ; H = high byte of offset
05AC: 11 7F 11              lxi  d, screen_area
05AF: 19                    dad  d        ; HL = screen_area + offset
05B0: D1                    pop  d
05B1: C9                    ret

                    ; -----------------------------------------------------------------------
                    ; init_stone -- initialize one 8-byte stone/ash particle structure
                    ; Input:  HL = pointer to 8-byte structure
                    ; Output: HL = pointer past the structure (HL+8)
                    ;
                    ; Stone structure (8 bytes, 16-bit fixed-point with 8.8 format):
                    ;   byte 0: x_vel_lo   - X velocity fraction (constant per stone)
                    ;   byte 1: x_pos_lo   - X position fraction
                    ;   byte 2: x_vel_hi   - X velocity integer (signed, constant per stone)
                    ;   byte 3: x_pos_hi   - X position integer (column 0-63)
                    ;   byte 4: y_vel_lo   - Y velocity fraction (+1 each frame = gravity)
                    ;   byte 5: y_vel_hi   - Y velocity integer (starts 0xFF = -1 = upward)
                    ;   byte 6: y_pos_lo   - Y position fraction
                    ;   byte 7: y_pos_hi   - Y position integer (row 0-24)
                    ;
                    ; Physics: x_pos += x_vel (constant horizontal drift)
                    ;          y_vel += 1 per frame (gravity acceleration)
                    ;          y_pos += y_vel (parabolic arc: starts upward, curves down)
                    ;
                    ; Spawns at volcano peak (columns 37-40, row 8) with random velocity.
                    ; Maps to Python's make_ash(x, y, vx, vy) + ash spawn logic.
                    ; -----------------------------------------------------------------------
05B2:               init_stone:               ; offset=05B2h
05B2: C5                    push b
05B3: 3E 03                 mvi  a, 3
05B5: CD F7 05              call random      ; random [0..3]
05B8: 4F                    mov  c, a        ; c = column offset
05B9: C6 25                 adi  25h         ; a = 37 + offset = column 37-40 (peak)
05BB: 57                    mov  d, a        ; d = x_pos_hi (initial column)
05BC: 3E FF                 mvi  a, 0FFh
05BE: CD F7 05              call random      ; random [0..255]
05C1: 5F                    mov  e, a        ; e = x_pos_lo (random fraction)
05C2: E6 FC                 ani  0FCh
05C4: B1                    ora  c           ; mix column offset into random byte
05C5: 0F                    rrc
05C6: 0F                    rrc              ; >>2: scale down
05C7: D6 80                 sui  80h         ; subtract 128 to center around 0 (signed)
05C9: 4F                    mov  c, a        ; c = x_vel_lo (signed random velocity)
05CA: 9F                    sbb  a           ; a = sign extension (0x00 or 0xFF)
05CB: 71                    mov  m, c        ; [0] x_vel_lo
05CC: 23                    inx  h
05CD: 73                    mov  m, e        ; [1] x_pos_lo (random)
05CE: 23                    inx  h
05CF: 77                    mov  m, a        ; [2] x_vel_hi (sign extension)
05D0: 23                    inx  h
05D1: 72                    mov  m, d        ; [3] x_pos_hi (column 37-40)
05D2: 23                    inx  h
05D3: A9                    xra  c           ; a = sign ^ vel_lo (derive Y vel from X vel)
05D4: D6 83                 sui  83h         ; bias upward
05D6: 77                    mov  m, a        ; [4] y_vel_lo (upward component)
05D7: 23                    inx  h
05D8: 36 FF                 mvi  m, 0FFh     ; [5] y_vel_hi = -1 (moving upward)
05DA: 23                    inx  h
05DB: 36 00                 mvi  m, 0        ; [6] y_pos_lo = 0
05DD: 23                    inx  h
05DE: 36 08                 mvi  m, 8        ; [7] y_pos_hi = row 8 (near volcano peak)
05E0: 23                    inx  h
05E1: C1                    pop  b
05E2: C9                    ret

                    ; Stone went off-screen -- rewind HL to start of structure, reinitialize
05E3:               respawn_stone:                         ; offset=05E3h

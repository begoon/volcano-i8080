0CDE:               slow_explosion_step:                ; offset=0CDEh
0CDE: 0E 2E                 mvi  c, 2Eh                ; '.'
0CE0: CD 92 0C              call explosion_radiate     ; draw dots
0CE3: 21 00 02              lxi  h, 200h               ; long delay (~512 iterations)
0CE6:               slow_explosion_delay:                   ; offset=0CE6h
0CE6: 2B                    dcx  h
0CE7: 7C                    mov  a, h
0CE8: B5                    ora  l
0CE9: C2 E6 0C              jnz  slow_explosion_delay

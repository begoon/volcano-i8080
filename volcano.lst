                    ; -----------------------------------------------------------------------
                    ; explosion -- fast expanding ring animation (helicopter crash)
                    ; Input: HL = position (row, col)
                    ; Expands dots '.' outward in 8 directions for 32 steps.
                    ; Each step: draw dots, short delay, erase dots. Fast animation.
                    ; -----------------------------------------------------------------------
0CBF:               explosion:             ; offset=0CBFh
0CBF: EB                    xchg          ; de = position (center of explosion)
0CC0: 06 00                 mvi  b, 0     ; b = radius (starts at 0)

0CC2:               explosion_step:                     ; offset=0CC2h
0CC2: 0E 2E                 mvi  c, 2Eh                ; '.' = explosion dot
0CC4: CD 92 0C              call explosion_radiate     ; draw dots at current radius
0CC7: 3E FF                 mvi  a, 0FFh               ; short delay (~255 iterations)
0CC9:               explosion_delay:                        ; offset=0CC9h
0CC9: 3D                    dcr  a
0CCA: C2 C9 0C              jnz  explosion_delay
0CCD: 0E 00                 mvi  c, 0                  ; c=0 = restore original chars
0CCF: CD 92 0C              call explosion_radiate     ; erase dots
0CD2: 04                    inr  b                     ; increase radius
0CD3: 78                    mov  a, b
0CD4: FE 20                 cpi  20h                   ; 32 steps total
0CD6: C2 C2 0C              jnz  explosion_step
0CD9: EB                    xchg
0CDA: C9                    ret

                    ; -----------------------------------------------------------------------

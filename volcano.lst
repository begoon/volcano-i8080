                    ; -----------------------------------------------------------------------
                    ; move_stone -- update one stone/ash particle position and draw it
                    ; Input:  HL = pointer to 8-byte stone structure (see init_stone)
                    ; Output: HL = pointer past the structure (HL+8)
                    ;
                    ; Updates position using 16-bit fixed-point arithmetic:
                    ;   x_pos += x_vel (constant horizontal drift)
                    ;   y_vel += 1 (gravity acceleration)
                    ;   y_pos += y_vel (vertical movement)
                    ; If stone goes off-screen (row >= 25 or col >= 64), respawns it.
                    ; Erases old '*' from screen, draws new '*' at updated position.
                    ; If new position hits helicopter 'O', triggers collision.
                    ; If new position has '-' (bullet), replaces with '+' (hit marker).
                    ; -----------------------------------------------------------------------
0517:               move_stone:                             ; offset=0517h
0517: C5                    push b
0518: 7E                    mov  a, m     ; [0] x_vel_lo
0519: 23                    inx  h
051A: 86                    add  m        ; + [1] x_pos_lo
051B: 77                    mov  m, a     ; [1] x_pos_lo += x_vel_lo
051C: 23                    inx  h
051D: 7E                    mov  a, m     ; [2] x_vel_hi
051E: 23                    inx  h
051F: 4E                    mov  c, m     ; c = [3] x_pos_hi (old column)
0520: 89                    adc  c        ; a = x_vel_hi + x_pos_hi + carry
0521: 77                    mov  m, a     ; [3] x_pos_hi = new column
0522: 47                    mov  b, a     ; b = new column
0523: 23                    inx  h
0524: 7E                    mov  a, m     ; [4] y_vel_lo
0525: C6 01                 adi  1        ; y_vel_lo += 1 (gravity!)
0527: 77                    mov  m, a     ; [4] y_vel_lo updated
0528: 5F                    mov  e, a     ; e = new y_vel_lo
0529: 23                    inx  h
052A: 7E                    mov  a, m     ; [5] y_vel_hi
052B: CE 00                 aci  0        ; y_vel_hi += carry from y_vel_lo overflow
052D: 77                    mov  m, a     ; [5] y_vel_hi updated
052E: 57                    mov  d, a     ; d = new y_vel_hi
052F: 23                    inx  h
0530: 7E                    mov  a, m     ; [6] y_pos_lo
0531: 83                    add  e        ; y_pos_lo += y_vel_lo
0532: 77                    mov  m, a     ; [6] y_pos_lo updated
0533: 23                    inx  h
0534: 7E                    mov  a, m     ; [7] y_pos_hi (old row)
0535: 5F                    mov  e, a     ; e = old row (for erasing)
0536: 8A                    adc  d        ; a = y_pos_hi + y_vel_hi + carry
0537: 77                    mov  m, a     ; [7] y_pos_hi = new row
0538: 57                    mov  d, a     ; d = new row
0539: 23                    inx  h        ; HL past the 8-byte structure
053A: E5                    push h
053B: FE 19                 cpi  19h      ; new row >= 25? (off screen bottom)

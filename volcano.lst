                    ; -----------------------------------------------------------------------
                    ; process_lava -- advance lava one row down the volcano
                    ; Decrements lava_level (which counts down from 0x10 toward 0).
                    ; Uses lava_levels table: each entry is 5 bytes:
                    ;   byte 0: count   - number of '+' chars to draw on this row
                    ;   byte 1: row     - screen row (Y coordinate)
                    ;   byte 2: column  - starting screen column (X coordinate)
                    ;   byte 3: human_row - row of person on this ledge (0 = no person)
                    ;   byte 4: human_col - column of person on this ledge
                    ; If a person ('I' or 'Y') is at the human position, they are killed
                    ; (erased, explosion triggered, soul created).
                    ; Maps to Python's lava_level increment + person kill check.
                    ; -----------------------------------------------------------------------
082F:               process_lava:                                ; offset=082Fh
082F: 3A AD 0F              lda  lava_level
0832: 3D                    dcr  a                              ; advance lava one step
0833: F8                    rm                                  ; if < 0, lava reached bottom, done
0834: 32 AD 0F              sta  lava_level
0837: 47                    mov  b, a
0838: 87                    add  a
0839: 87                    add  a
083A: 80                    add  b                              ; a = lava_level * 5
083B: 5F                    mov  e, a
083C: 16 00                 mvi  d, 0                           ; de = lava_level * 5
083E: 21 74 0D              lxi  h, lava_levels
0841: 19                    dad  d                              ; hl = &lava_levels[lava_level]
0842: 46                    mov  b, m                           ; b = count (number of '+' to draw)
0843: 23                    inx  h
0844: 5E                    mov  e, m                           ; e = row
0845: 23                    inx  h
0846: 56                    mov  d, m                           ; d = column
0847: EB                    xchg                                ; hl = row,col for cursor; de = table ptr
0848: CD 9B 05              call set_cursor_in_screen_arena     ; set cursor + get buffer ptr

084B: 0E 2B                 mvi  c, 2Bh     ; '+' = lava character
084D:               lava_fill_loop:                ; offset=084Dh
084D: CD 09 F8              call monitor_cout     ; draw '+' on screen
0850: 71                    mov  m, c             ; write '+' to screen buffer
0851: 23                    inx  h
0852: 05                    dcr  b
0853: C2 4D 08              jnz  lava_fill_loop

0856: CD 68 0D              call beep
0859: EB                    xchg       ; hl = table ptr (at byte 2)
085A: 23                    inx  h     ; hl -> byte 3 (human_row)
085B: 7E                    mov  a, m
085C: B7                    ora  a
085D: C8                    rz         ; human_row == 0 means no person here

                            ; Check if person is still alive at this position

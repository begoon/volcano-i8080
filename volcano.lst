                    ; -----------------------------------------------------------------------
                    ; process_bullet -- update one bullet position
                    ; Input: HL = pointer to 4-byte bullet entry
                    ; Output: HL = pointer past entry (+4)
                    ;
                    ; Bullet structure (4 bytes):
                    ;   byte 0: active flag / step direction (0=free, 1/-1=direction)
                    ;   byte 1: X delta per step (+1 or -1)
                    ;   byte 2: current row (Y)
                    ;   byte 3: current column (X)
                    ;
                    ; Each tick: erases '-' at old position, advances X by delta.
                    ; Collision checks at new position:
                    ;   'O' (helicopter) -> skip erase, advance cursor, recheck
                    ;   '*' (stone) -> replace with '+' (destroyed stone)
                    ;   'I'/'Y' (person) -> kill person, free bullet
                    ;   space -> draw '-' at new position
                    ;   anything else -> free bullet (hit terrain/wall)
                    ; Bullets move 2 cells per game tick (called twice in game_loop).
                    ; -----------------------------------------------------------------------
0B69:               process_bullet:                         ; offset=0B69h
0B69: C5                    push b
0B6A: 4E                    mov  c, m                  ; bullet's step X
0B6B: 23                    inx  h
0B6C: 46                    mov  b, m
0B6D: 23                    inx  h
0B6E: 5E                    mov  e, m
0B6F: 23                    inx  h
0B70: 56                    mov  d, m                  ; de = bullet XY
0B71: E5                    push h
0B72: 79                    mov  a, c
0B73: B7                    ora  a
0B74: CA D5 0B              jz   free_bullet_entry     ; if the bullet entry is zero, exit
0B77: EB                    xchg
0B78: CD 80 05              call set_cursor
0B7B: EB                    xchg
0B7C: 6A                    mov  l, d
0B7D: 7B                    mov  a, e
0B7E: CD A0 05              call screen_area_address
0B81: 7E                    mov  a, m
0B82: FE 4F                 cpi  4Fh                   ; 'O'
0B84: CA E3 0B              jz   bullet_skip_heli
0B87: 36 20                 mvi  m, 20h                ; ' '
0B89: C5                    push b
0B8A: 0E 20                 mvi  c, 20h                ; ' '
0B8C: CD 09 F8              call monitor_cout
0B8F: C1                    pop  b
0B90: FE 2D                 cpi  2Dh                   ; '-'
0B92: C2 D5 0B              jnz  free_bullet_entry     ; hl    -= 4

0B95:               bullet_advance:                         ; offset=0B95h
0B95: 7A                    mov  a, d                  ; recalculate bullet X
0B96: 81                    add  c
0B97: FE 40                 cpi  40h                   ; '@'
